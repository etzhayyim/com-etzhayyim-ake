    { "name": "review_vote", "module": "ake.cells.review_vote", "murakumoNode": "levi", "phase": "optimistic fast-path / 1 SBT = 1 vote with timelock / Council-pending; no-server-key tally", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.ake.editReview", "gates": ["G7"] },
    { "name": "promote", "module": "ake.cells.promote", "murakumoNode": "judah", "phase": "no-server-key promotion membrane; append revision + :representative→:authoritative; published=false at R0", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.ake.editPromotion", "gates": ["G4", "G8", "G9"] },
