  "constitutionalGates": {
    "description": "9 immutable gates per ADR-2606052100. G1 (信者-gated + no-server-key), G2 (LLM non-adjudicating), G3 (mirror-preserving), and G5 (append-only) are the structural anchors; each lives in three places (schema :db/allowed + lexicon :const/:enum + Python ValueError).",
    "gates": {
      "G1": "信者-gated + member-signed — :edit/author-kind :db/allowed [:member]; :server/:anon unrepresentable; serverHeldKey const false (no-server-key, ADR-2605231525). NOT anonymous open-edit.",
      "G2": "LLM non-adjudicating — triage emits :triage/risk + :triage/quality + :triage/route only; :triage/decision does not exist; route is a PURE FUNCTION of (risk,quality). The model scores, it never accepts/rejects.",
      "G3": "Mirror-preserving — :edit/target-kind ∈ {:kg-fact :actor-profile}; :entity-speech/:impersonate unrepresentable; an entity-actor is corrected as an OBSERVATION, never spoken-as (ADR-2606042330).",
      "G4": "Sourcing-mandatory — :edit/provenance required (ValueError if absent); :representative→:authoritative promotion needs verifiable provenance (ooyake G20 precedent).",
      "G5": "Append-only / non-destructive — proposal/accept/reject/challenge/revert are ALL appended datoms; :delete/:overwrite unrepresentable; full revision history replayable (kotoba-canonical ADR-2605312345 + 非終末論).",
      "G6": "Murakumo-only inference (ADR-2605215000) — any LLM scoring refinement runs on the Murakumo fleet.",
      "G7": "Invariant-lock escalation — edits touching constitutional invariants (charter §, force-class, license, no-server-key, an actor's own gates) route to Council Lv7+ (never optimistic-accept); a Charter-Rider §2(a)-(h) hit is :refused upstream (ADR-2605192200).",
      "G8": "Outward-gated — live ingest / binding vote / promotion / publish = Council Lv6+ + operator; published const false at R0.",
      "G9": "Anti-vandalism / contributor-trajectory — per-DID rate + a Wellbecoming acceptance history (as-of), NOT a punitive score-of-soul (kizashi G8 precedent)."
    }
  },
  "nonGoals": {
    "description": "7 explicitly excluded scopes",
    "goals": {
      "N1": "NOT anonymous open-edit — 信者-gated + member-signed (G1). The charter requires conversion-gated, signed contribution; this is a permissioned wiki, not Wikipedia's anonymous model.",
      "N2": "The LLM never decides accept/reject (G2) — it scores risk+quality and routes.",
      "N3": "No impersonation / no speak-as-entity (G3) — mirror corrected as observation only.",
      "N4": "No overwrite / no deletion of history (G5).",
      "N5": "No unsourced edits (G4).",
      "N6": "No server-signed edits / no platform-held key (G1/no-server-key).",
      "N7": "Not an arbiter of legal/criminal truth (danjo/chigiri boundary) — 朱 corrects records, it does not adjudicate disputes of law."
    }
  },
  "roadmap": [
    { "phase": "R0", "date": "2026-06-05", "scope": "This ADR. Ontology + 6 lexicons + 5 cells + triage engine + revision-history engine + contributor-trajectory engine + edit-war revert (challenge→rollback) + end-to-end membrane + genesis-revision bridge over the REAL actor-profile SSoT + :representative seed + SSoT drift-lock + cell-chain membrane-flow integration + hermetic fixture (committed). 110 tests green (hermetic). No live ingest/vote/promotion/publish.", "gate": "ADR-2606052100 (PROPOSED)" },
