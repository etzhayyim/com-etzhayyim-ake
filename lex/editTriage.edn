{:lexicon 1
 :id "com.etzhayyim.ake.editTriage"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :description "G2 INVARIANT — the LLM-advisory triage of a proposal. It carries a risk class, a 0..1 quality score (Wikipedia ORES analogue), and a route. It has NO 'decision' property by design: the model SCORES and ROUTES, it never accepts or rejects (非裁定). Acceptance authority is the optimistic threshold rule OR 1 SBT = 1 vote OR Council — never the model. Inference is Murakumo-only (G6)."
   :record
   {:type "object"
    :required ["editId" "risk" "quality" "route"]
    :properties
    {:editId  {:type "string" :description "→ :triage/edit"}
     :risk    {:type "string" :enum ["low" "medium" "high" "invariant"]
               :description "a SCORE, not a verdict"}
     :quality {:type "number" :description "0..1 sourcing + plausibility + Rider-clean score"}
     :route   {:type "string" :enum ["auto-accept" "vote" "council-lv7" "refused"]
               :description "G2 INVARIANT — a PURE FUNCTION of (risk, quality). 'accept'/'reject' are NOT routes; the model does not emit a decision."}
     :by      {:type "string" :description "G6 — Murakumo model id; advisory only"}}}}}}
