{:lexicon 1
 :id "com.etzhayyim.ake.revisionEntry"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :description "One entry in the append-only revision history of an entity attribute — the 'view history' tab. Every accept / retract / sourcing-promotion / challenge appends one of these; nothing is ever overwritten or deleted (G5, 非終末論). The latest as-of entry is the current value; the full stream is the history."
   :record
   {:type "object"
    :required ["entity" "attr" "asOf" "op"]
    :properties
    {:entity   {:type "string"}
     :attr     {:type "string"}
     :value    {:type "string"}
     :sourcing {:type "string" :enum ["representative" "authoritative"]}
     :asOf     {:type "integer"}
     :by       {:type "string" :description "the member DID whose edit produced this revision"}
     :op       {:type "string" :enum ["assert" "retract" "promote-sourcing" "challenge"]
                :description "G5 — delete / overwrite are NOT enum members"}
     :editId   {:type "string" :description "→ the :edit/id that produced this revision"}}}}}}
