{:lexicon 1
 :id "com.etzhayyim.ake.councilEditReview"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :description "Council attestation for an invariant-adjacent edit (G7). When a proposal touches a constitutional invariant (charter §, force-class, license, no-server-key, an actor's own gates) the triage route is :council-lv7 — never optimistic-accept and never a simple SBT vote. The Charter Rider §2(a)-(h) scan is a hard pre-gate (a hit → the proposal is :refused upstream, never reaches Council)."
   :record
   {:type "object"
    :required ["editId" "level" "outcome"]
    :properties
    {:editId        {:type "string"}
     :level         {:type "string" :const "Lv7"
                     :description "G7 — invariant-adjacent edits need Council Lv7+ (the amendment threshold), not Lv6+"}
     :riderScanClean {:type "boolean" :description "Charter Rider §2(a)-(h) scan result; a false here means the edit never should have reached Council"}
     :attestedBy    {:type "string" :description "Council member DIDs (≥ Lv7 unanimity)"}
     :outcome       {:type "string" :enum ["accepted" "rejected"]}}}}}}
