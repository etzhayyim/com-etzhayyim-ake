{:lexicon 1
 :id "com.etzhayyim.ake.editReview"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :description "The community review of an escalated proposal: 1 SBT = 1 vote (with a timelock) for risky/contested edits, the optimistic fast-path for low-risk well-sourced edits, or Council Lv7+ for invariant-adjacent edits. Mirrors Wikipedia's discussion/RfC, but every vote is an on-chain SBT signature."
   :record
   {:type "object"
    :required ["editId" "mechanism" "outcome"]
    :properties
    {:editId     {:type "string" :description "→ :review/edit"}
     :mechanism  {:type "string" :enum ["optimistic" "sbt-vote" "council-lv7"]}
     :yes        {:type "integer" :description "1 SBT = 1 vote tally (sbt-vote)"}
     :no         {:type "integer"}
     :timelockH  {:type "integer" :description "hours the vote stayed open before tally (48h default)"}
     :outcome    {:type "string" :enum ["accepted" "rejected" "pending"]}
     :signedBy   {:type "string" :description "tally attestor DID (member/operator; never server)"}}}}}}
