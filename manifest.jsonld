    { "phase": "R2", "date": "post-R1", "scope": "Standing community-correction service across all KG actors; contributor-trajectory dashboards; dispute/edit-war resolution wired to danjo observation + Council; the :representative→:authoritative promotion pipeline driving ooyake/kabuto coverage honesty.", "gate": "Future ADR + Council Lv6+ + operator" }
  ],
